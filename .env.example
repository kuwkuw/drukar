# ── LLM (agent loop) ──────────────────────────────────────────────────────────
# LLM backend driving the agent loop:
# anthropic – Claude via the Anthropic API (default), requires ANTHROPIC_API_KEY
# openai    – any chat-completions-compatible server: OpenAI, Ollama (local),
#             OpenRouter, Groq, Mistral, Gemini compat endpoint
DRUKAR_LLM_PROVIDER=anthropic
# Anthropic API key. Required only for live agent runs; tests use a mocked client.
ANTHROPIC_API_KEY=
# Model used by the agent loop (interpreted by the selected provider).
DRUKAR_MODEL=claude-fable-5
# openai provider only: base URL + API key of the chat-completions server.
# Ollama example: DRUKAR_LLM_BASE_URL=http://localhost:11434/v1  DRUKAR_MODEL=qwen3:8b
# (no key needed for Ollama; falls back to OPENAI_API_KEY if unset)
DRUKAR_LLM_BASE_URL=
DRUKAR_LLM_API_KEY=

# ── 3D generation provider ────────────────────────────────────────────────────
# mock  – programmatic sample meshes, runs fully offline, zero API keys (default)
# tripo – Tripo3D platform API (https://platform.tripo3d.ai), requires TRIPO_API_KEY
# hf    – free Hugging Face gradio Space (default: hysts/Shap-E), zero keys required
DRUKAR_PROVIDER=mock
TRIPO_API_KEY=
# Optional Tripo model_version (e.g. v2.5); leave blank to use the account default.
TRIPO_MODEL_VERSION=
# hf provider only: override the Space (any gradio Space with a text→Model3D endpoint).
DRUKAR_HF_SPACE_URL=
# Optional HF token — anonymous calls work but get a smaller free ZeroGPU quota.
HF_TOKEN=

# ── API server ────────────────────────────────────────────────────────────────
DRUKAR_API_PORT=3000
DRUKAR_API_HOST=0.0.0.0
# Directory for job state snapshots and mesh artifacts.
DRUKAR_DATA_DIR=./data
# Per-IP rate limits (the API has no auth; this is the public deploy's spend brake).
# 0 = disabled — the right setting for local dev, and this file's default. Production
# leaves these unset and runs the built-in defaults: 300/min global, 10/min chat.
DRUKAR_RATE_LIMIT_MAX=0
# Stricter cap for POST /api/chat — each call can spend LLM + generation credits.
DRUKAR_CHAT_RATE_LIMIT_MAX=10
# Window for both limits, in milliseconds.
DRUKAR_RATE_LIMIT_WINDOW_MS=60000
# Set to true only behind a reverse proxy (Render, nginx) so limits key on the real
# client IP from X-Forwarded-For instead of the proxy's address.
DRUKAR_TRUST_PROXY=false

# ── Printability thresholds ───────────────────────────────────────────────────
# Minimum wall thickness in millimetres, per process/material.
DRUKAR_MIN_WALL_MM_FDM=1.2
DRUKAR_MIN_WALL_MM_RESIN=0.8
# Max share of surface area (0..1) allowed to measure thinner than the minimum wall.
# Tapering tips/edges always measure near zero somewhere; only extended thin regions fail.
DRUKAR_THIN_WALL_MAX_RATIO=0.05
# Faces tilted more than this many degrees from vertical count as overhangs.
DRUKAR_OVERHANG_DEG=50
# Maximum share of overhang faces before the overhang check fails (0..1).
DRUKAR_OVERHANG_MAX_RATIO=0.3
# Printer build volume in millimetres, WxDxH.
DRUKAR_BUILD_VOLUME=220x220x250

# ── Job lifecycle ─────────────────────────────────────────────────────────────
# Maximum regeneration attempts after a failed validation (initial attempt excluded).
DRUKAR_MAX_REGENERATIONS=2
