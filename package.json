{
  "name": "drukar",
  "version": "0.1.0",
  "private": true,
  "description": "AI agent that turns a plain-text description into a print-ready 3D model file",
  "packageManager": "pnpm@10.34.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @drukar/api --filter @drukar/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pipeline:run": "pnpm --filter @drukar/api pipeline:run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
